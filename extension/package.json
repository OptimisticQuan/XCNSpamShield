{
  "name": "xcnspamshield-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.content.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "package": "pnpm build"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "idb": "^8.0.2",
    "onnxruntime-web": "^1.26.0",
    "paddleocr": "^1.1.1",
    "pinyin-pro": "^3.26.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/chrome": "^0.0.329",
    "@types/node": "^22.15.17",
    "eslint": "^9.26.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vite-plugin-static-copy": "^3.1.1",
    "vitest": "^3.1.2"
  }
